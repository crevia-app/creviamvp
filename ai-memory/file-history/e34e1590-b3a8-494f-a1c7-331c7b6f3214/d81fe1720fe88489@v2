-- ============================================================
-- Requirement 3: Strict RBAC – admin role locked to room creator
-- Requirement 4: Bulletproof single-use invite links
-- ============================================================

-- ── 1. workspace_invites table ────────────────────────────────
CREATE TABLE IF NOT EXISTS workspace_invites (
  id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  token       TEXT        UNIQUE NOT NULL DEFAULT encode(gen_random_bytes(32), 'hex'),
  room_id     UUID        NOT NULL REFERENCES chat_rooms(id) ON DELETE CASCADE,
  invited_by  UUID        NOT NULL REFERENCES profiles(id)   ON DELETE CASCADE,
  used_by     UUID        REFERENCES profiles(id)            ON DELETE SET NULL,
  accepted_at TIMESTAMPTZ,
  expires_at  TIMESTAMPTZ NOT NULL DEFAULT (NOW() + INTERVAL '7 days'),
  created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

ALTER TABLE workspace_invites ENABLE ROW LEVEL SECURITY;

-- Room creator can generate invites
CREATE POLICY "invite_insert_creator_only" ON workspace_invites
  FOR INSERT WITH CHECK (
    invited_by = auth.uid()
    AND EXISTS (
      SELECT 1 FROM chat_rooms
      WHERE id = room_id AND created_by = auth.uid()
    )
  );

-- Anyone authenticated can read an invite by token (needed to accept)
CREATE POLICY "invite_select_authenticated" ON workspace_invites
  FOR SELECT USING (auth.uid() IS NOT NULL);

-- Any authenticated user can mark an invite as used (accept flow)
CREATE POLICY "invite_update_accept" ON workspace_invites
  FOR UPDATE USING (auth.uid() IS NOT NULL)
  WITH CHECK (
    -- Can only accept once; re-accepting is idempotent if used_by = self
    used_by IS NULL OR used_by = auth.uid()
  );


-- ── 2. RBAC: prevent role escalation in chat_room_members ─────
-- A new member row may only carry role='admin' if the inserting user IS
-- the room's creator AND is inserting their own user_id.
-- All other inserts must use role='member'.

DROP POLICY IF EXISTS "chat_room_members_insert" ON chat_room_members;

CREATE POLICY "chat_room_members_insert_rbac" ON chat_room_members
  FOR INSERT WITH CHECK (
    -- Option A: inserting with role='member' (always allowed for room members)
    role = 'member'
    OR
    -- Option B: inserting role='admin' only if this user is the room creator
    (
      role = 'admin'
      AND user_id = auth.uid()
      AND EXISTS (
        SELECT 1 FROM chat_rooms
        WHERE id = room_id AND created_by = auth.uid()
      )
    )
  );

-- Prevent any UPDATE that escalates an existing row to admin
-- (only the DB-level trigger / server-side logic may change roles)
DROP POLICY IF EXISTS "chat_room_members_update" ON chat_room_members;

CREATE POLICY "chat_room_members_no_role_escalation" ON chat_room_members
  FOR UPDATE USING (true)
  WITH CHECK (
    -- Disallow flipping any row to admin=true unless updater is room creator
    role != 'admin'
    OR EXISTS (
      SELECT 1 FROM chat_rooms
      WHERE id = room_id AND created_by = auth.uid()
    )
  );


-- ── 3. Helper function: accept_workspace_invite (idempotent) ──
-- Accepts an invite token for the current user.
-- Returns the room_id so the client can navigate to the workspace.
CREATE OR REPLACE FUNCTION accept_workspace_invite(p_token TEXT)
RETURNS UUID
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
DECLARE
  v_invite  workspace_invites%ROWTYPE;
  v_user_id UUID := auth.uid();
BEGIN
  -- 1. Load and validate invite
  SELECT * INTO v_invite
  FROM workspace_invites
  WHERE token = p_token
    AND expires_at > NOW();

  IF NOT FOUND THEN
    RAISE EXCEPTION 'invalid_or_expired_invite';
  END IF;

  -- 2. Idempotency: if already a member, just return the room_id
  IF EXISTS (
    SELECT 1 FROM chat_room_members
    WHERE room_id = v_invite.room_id AND user_id = v_user_id
  ) THEN
    RETURN v_invite.room_id;
  END IF;

  -- 3. Add user as member
  INSERT INTO chat_room_members (room_id, user_id, role)
  VALUES (v_invite.room_id, v_user_id, 'member')
  ON CONFLICT (room_id, user_id) DO NOTHING;

  -- 4. Mark invite as used (idempotent: only mark if not already used)
  UPDATE workspace_invites
  SET used_by = v_user_id, accepted_at = NOW()
  WHERE id = v_invite.id AND used_by IS NULL;

  RETURN v_invite.room_id;
END;
$$;

GRANT EXECUTE ON FUNCTION accept_workspace_invite(TEXT) TO authenticated;
