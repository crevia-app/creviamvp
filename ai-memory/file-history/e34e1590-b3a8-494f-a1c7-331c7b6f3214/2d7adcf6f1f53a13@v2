-- ────────────────────────────────────────────────────────────
-- RLS Security Fixes  (2026-05-12)
-- ────────────────────────────────────────────────────────────

-- ── 1. workspace_invites ─────────────────────────────────────
-- Old SELECT: any authenticated user → could enumerate all tokens
-- Old UPDATE: any authenticated user → could tamper with any invite

DROP POLICY IF EXISTS "invite_select_authenticated" ON workspace_invites;
DROP POLICY IF EXISTS "invite_update_accept"        ON workspace_invites;

-- Only the creator who sent the invite, or the user who accepted it, can read it.
-- The accept_workspace_invite() SECURITY DEFINER function handles the actual join,
-- so the SELECT is only needed for UI display (e.g. "invite sent" confirmation).
CREATE POLICY "invite_select_own"
  ON workspace_invites FOR SELECT
  USING (
    invited_by = auth.uid()
    OR used_by  = auth.uid()
    OR room_id  IN (
      SELECT id FROM chat_rooms WHERE created_by = auth.uid()
    )
  );

-- Only the person accepting the invite (used_by) can mark it as consumed.
-- The SECURITY DEFINER accept_workspace_invite() RPC is the canonical path —
-- this policy is a belt-and-suspenders guard against direct UPDATE calls.
CREATE POLICY "invite_update_accept_own"
  ON workspace_invites FOR UPDATE
  USING  (used_by IS NULL)
  WITH CHECK (used_by = auth.uid());


-- ── 2. feedback ──────────────────────────────────────────────
-- Old SELECT: any authenticated user → exposed all users' private feedback
-- Fix: users can only read their own submissions; admin reads via service role.

DROP POLICY IF EXISTS "feedback_select" ON feedback;

CREATE POLICY "feedback_select_own"
  ON feedback FOR SELECT
  USING (user_id = auth.uid());


-- ── 3. chat_messages UPDATE ──────────────────────────────────
-- Old UPDATE: USING (sender_id = auth.uid()) but no WITH CHECK
-- This allowed senders to retroactively change message content to anything,
-- including injecting HTML or switching room_id.

DROP POLICY IF EXISTS "Senders can update own messages" ON chat_messages;

CREATE POLICY "Senders can update own messages"
  ON chat_messages FOR UPDATE
  USING (sender_id = auth.uid())
  WITH CHECK (
    sender_id = auth.uid()
    AND room_id = room_id  -- prevent room_id reassignment
  );


-- ── 4. notifications: missing INSERT policy ───────────────────
-- Notifications are written only by SECURITY DEFINER trigger functions,
-- not by users directly — but there's no INSERT policy, which means the
-- anon/authenticated role can't insert at all (fine) but also means the
-- trigger functions rely purely on SECURITY DEFINER to bypass RLS.
-- Explicit denial makes the intent clear and prevents future regressions.

DROP POLICY IF EXISTS "notif_insert_deny" ON notifications;

CREATE POLICY "notif_insert_deny"
  ON notifications FOR INSERT
  WITH CHECK (false);

-- Allow the SECURITY DEFINER notify functions to still insert via:
-- They already run as the function owner (postgres/service role),
-- which bypasses RLS entirely — so WITH CHECK (false) only blocks
-- direct client inserts. No functional change, just explicit intent.
