-- Fix chat_messages.invoice_id FK to use SET NULL on invoice deletion.
-- Without this, deleting a user fails because their invoices can't be
-- removed while chat_messages still reference them.
ALTER TABLE public.chat_messages
  DROP CONSTRAINT IF EXISTS chat_messages_invoice_id_fkey;

ALTER TABLE public.chat_messages
  ADD CONSTRAINT chat_messages_invoice_id_fkey
  FOREIGN KEY (invoice_id)
  REFERENCES public.invoices(id)
  ON DELETE SET NULL;
